def std = @import("std");
def std_exp = @import("./std_exp.pthr");


type PantherBuild = struct {

	type Output = union {
		exectuable : Executable,
		run        : Void,
		object     : Object,
		assembly   : Assembly,
		llvmir     : LLVMIR,
		pir        : PIR,
		sema       : Void,
		ast        : AST,
		tokens     : Tokens,
		

		type Executable = struct {
			var path: [Char:*];
			var windowedMode: Bool = false;
		}

		type Object = struct {
			var path: [Char:*];
		}

		type Assembly = struct {
			var path: [Char:*];
		}

		type LLVMIR = struct {
			var path: [Char:*]?; // null if out to console
		}

		type PIR = struct {
			var path: [Char:*]?; // null if out to console
		}

		type AST = struct {
			var path: [Char:*]?; // null if out to console
		}

		type Tokens = struct {
			var path: [Char:*]?; // null if out to console
		}

	}

	
}
def std = @import("std");
def std_exp = @import("./std_exp.pthr");




type CFamilyHeader = alias #pub @build.PantherBuildConfigCFamilyHeader;

type Package = struct #pub {
	type Directory = alias @build.PantherBuildConfigDirectory;

	var path: [Char:*];
	var name: [Char:*];
	var warnings: @build.PackageWarningSettings;
	var sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>();
	var sourceDirectories = new std_exp.StaticArrayList<{Directory, 4}>();
}


type Target = struct #pub {
	var os: OS;
	var arch: Arch;

	type OS = enum(UI32) {
		WINDOWS = 0,
	}

	type Arch = enum(UI32) {
		X86_64 = 0,
	}
}





type PantherBuild = struct #pub {
	type Output = alias @build.PantherBuildConfigOutput;
	type ExecutableOutput = alias @build.PantherBuildConfigExecutableOutput;

	var output: Output;

	var target: Target;
	var optimization: Optimiziation;

	var addDebugInfo: Bool = false;
	var numThreads: UI32 = 0;

	var packages = new std_exp.StaticArrayList<{Package, 16}>();
	var cFamilyHeaders = new std_exp.StaticArrayList<{CFamilyHeader, 4}>();


	func delete = (this) -> Void {
		std.debug.assert(this.built, "Didn't call PantherBuild.build()");
	}


	func build = (this mut) #rt -> Void <Void> {
		var packages = new std_exp.StaticArrayList<{@build.PantherBuildConfigPackage, 16}>();

		for(this.packages) [_; package: Package] {
			packages.append().* = new @build.PantherBuildConfigPackage{
				path              = copy package.path,
				name              = copy package.name,
				warnings          = copy package.warnings,
				sourceFiles       = package.sourceFiles as [[Char:*]:*],
				sourceDirectories = package.sourceDirectories as [@build.PantherBuildConfigDirectory:*],
			};
		}

		this.built = true;

		const build_was_successful: Bool = @createPantherBuild(
			new @build.PantherBuildConfig{
				output         = copy this.output,
				numThreads     = copy this.numThreads,
				addDebugInfo   = copy this.addDebugInfo,
				packages       = packages as [@build.PantherBuildConfigPackage:*],
				cFamilyHeaders = this.cFamilyHeaders as [@build.PantherBuildConfigCFamilyHeader:*],
			}
		);

		if(build_was_successful == false){ error; }
	}


	func addStdLib = (this mut, path: [Char:*]) -> Void {
		const warns = new @build.PackageWarningSettings{
			methodCallOnNonMethod        = true,
			memberTypeByValueAccessor    = true,
			deleteMovedFromExpr          = true,
			deleteTriviallyDeletableType = true,
			comptimeIfCond               = true,
			alreadyUnsafe                = true,
			experimentalF80              = true,
		};


		const package_std_uninit: Package*uninit = this.packages.append();
		package_std_uninit.* = new Package{
			path              = copy path,
			name              = "std",
			warnings          = copy warns,
			sourceFiles       = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./std.pthr"],
			),
			sourceDirectories = new std_exp.StaticArrayList<{Package.Directory, 4}>(
				new [Package.Directory:1][new Package.Directory{path = "./containers", isRecursive = true}]
			),
		};


		this.packages.append().* = new Package{
			path              = copy path,
			name              = "std._compiler_rt",
			warnings          = copy warns,
			sourceDirectories = new std_exp.StaticArrayList<{Package.Directory, 4}>(
				new [Package.Directory:1][new Package.Directory{path = "./compiler_rt", isRecursive = true}]
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.bit",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./bit.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.build",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./building.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.debug",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./debug.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.math",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./math.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.mem",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./mem.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.ptrMath",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./ptrMath.pthr"],
			),
		};

		this.packages.append().* = new Package{
			path        = copy path,
			name        = "std.types",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
				new [[Char:*]:1]["./types.pthr"],
			),
		};
	}



	type Optimiziation = struct {
		
	}


	///////////////////////////////////
	// private

	var built: Bool #priv = false;
}

def std = @import("std");
def std_exp = @import("./std_exp.pthr");




type Package = struct #pub {
	type Directory = struct {
		var path: [Char:*];
		var isRecursive: Bool;
	}


	var path: [Char:*];
	var name: [Char:*];
	var warnings: @build.PackageWarningSettings;
	var sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>();
	var sourceDirectories = new std_exp.StaticArrayList<{Directory, 16}>();
}



type Build = struct #pub {
	func delete = (this) -> Void {
		std.assert(this.built, "Didn't call Build.build()");
	}


	func build = (this mut) #rt -> Void {
		std.assert(this.built == false, "Already built");

		@buildSetOutput(this.output as UI32);
		@buildSetNumThreads(this.numThreads);

		for(this.packages) [i: USize; package: Package] {
			this.add_package(package);
		}

		this.built = true;
	}

	func createPackage = (this mut) -> Package*uninit {
		return this.packages.append();
	}


	func addStdLib = (this mut, path: [Char:*]) -> Void {
		const warns = new @build.PackageWarningSettings{
			methodCallOnNonMethod        = true,
			memberTypeByValueAccessor    = true,
			deleteMovedFromExpr          = true,
			deleteTriviallyDeletableType = true,
			comptimeIfCond               = true,
			alreadyUnsafe                = true,
			experimentalF80              = true,
		};


		const package_std_uninit: Package*uninit = this.createPackage();
		package_std_uninit.* = new Package{
			path              = copy path,
			name              = "std",
			warnings          = copy warns,
			sourceFiles       = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:2]["./asserts.pthr", "./std.pthr"],
			),
			sourceDirectories = new std_exp.StaticArrayList<{Package.Directory, 16}>(
				new [Package.Directory:1][new Package.Directory{path = "./containers", isRecursive = true}]
			),
		};
		this.std_lib_package = @makeInitPtr(package_std_uninit);


		this.createPackage().* = new Package{
			path              = copy path,
			name              = "std._compiler_rt",
			warnings          = copy warns,
			sourceDirectories = new std_exp.StaticArrayList<{Package.Directory, 16}>(
				new [Package.Directory:1][new Package.Directory{path = "./compiler_rt", isRecursive = true}]
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.bit",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./bit.pthr"],
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.build",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./building.pthr"],
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.math",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./math.pthr"],
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.mem",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./mem.pthr"],
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.ptrMath",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./ptrMath.pthr"],
			),
		};

		this.createPackage().* = new Package{
			path        = copy path,
			name        = "std.types",
			warnings    = copy warns,
			sourceFiles = new std_exp.StaticArrayList<{[Char:*], 16}>(
				new [[Char:*]:1]["./types.pthr"],
			),
		};
	}



	var output: std.build.Output;
	var numThreads: UI32 = 0;



	///////////////////////////////////
	// private

	func add_package = (this, package: Package) #rt #priv -> Void {
		const package_id: @build.PackageID = @buildCreatePackage(package.path, package.name, copy package.warnings);

		for(package.sourceFiles) [_; src_file: [Char:*]] {
			@buildAddSourceFile(src_file, package_id);
		}

		for(package.sourceDirectories) [_; src_dir: Package.Directory] {
			std.assert(src_dir.isRecursive);
			@buildAddSourceDirectory(src_dir.path, package_id, src_dir.isRecursive);
		}

		if(this.std_lib_package != null && &package == this.std_lib_package.?){
			@buildSetStdLibPackage(package_id);
		}
	}

	var packages #priv = new std_exp.StaticArrayList<{Package, 16}>();
	var built: Bool #priv = false;
	var std_lib_package: Package*? = null;
}


type Ptr = struct <{T: Type}> {
	var ptr: T*;
}



var dst: Ptr<{Int}> = get_src();
const src: Int = 12;


func get_src = () -> Ptr<{Int}> {
	const fake_ptr: Int* = {->expr:Int*
		unsafe{
			return->expr @bitCast<{USize, Int*}>(1212);
		}
	};

	return new Ptr<{Int}>{ptr = copy fake_ptr};
}







interface Interface = #polymorphic {
	func get_num = () -> Int;
}


type Struct = struct {
	impl Interface{
		get_num = () -> Int { return 12; }
	}
}


const foo = new Struct();
const bar: impl(*:Interface) = get_interface();


func get_interface = () -> impl(*:Interface) {
	return foo as impl(*:Interface);
}

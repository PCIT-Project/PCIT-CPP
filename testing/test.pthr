def std = @import("std");
def std_exp = @import("std_exp/std_exp.pthr");

func sum = (arr: [UI8:*]) -> (output: UI8) {
	output = 0;

	for(arr) [_; value: UI8] {
		output += value;
	}

	return...;
}

func entry = () #entry -> UI8 {
	var arr = new std_exp.StaticArrayList<{UI8, 3}>();
	arr.append().* = 12;
	arr.append().* = 14;
	arr.append().* = 16;
	
	return sum(arr);
}
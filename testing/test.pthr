

type Struct = struct {
	func new = (num: Int) -> (output: Struct) {
		output.flag = true;
		output.num = copy num;
		output.num_2 = 2;
		return...;
	}

	func get_num = (this) -> Int {
		return copy this.num;
	}

	var flag: Bool;
	var num: Int;
	var num_2: Int;
}



const s = new Struct(13);
const s_num: Int = copy s.num;






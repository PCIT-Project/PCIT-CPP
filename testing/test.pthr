type Struct = struct {
	var foo: Int;
	var bar: Int;
}

func discard = (val: $T read) -> T? {
	return null;
}


func entry = () #entry -> UI8 {
	// var foo: Int = 12;
	var arr = new [Int:3][1, 2, 3];

	// _ = discard(copy foo);
	// _ = discard(&foo);
	// _ = discard(new Struct{foo = 12, bar = 14});

	_ = discard(arr as [Int:*mut]);
	
	return 0;
}


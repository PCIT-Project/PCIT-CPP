type Struct = struct {
	var num: Int;
}

const foo = new Struct{num = 12};
const bar: Int = get_struct_num<{copy foo}>();


func get_struct_num = <{S: Struct}> (num_to_add: Int = 0) -> Int {
	return S.num + num_to_add;
}


func test = () #rt -> Void {
	var local_var: Int = 12;
	def TEST = get_struct_num<{copy foo}>(local_var);
}




func get_foo_as_byte_arr = () #unsafe -> [Byte:8] {
	def ARR: [Byte:8] = @bitCast<{Struct, [Byte:8]}>(foo);
	return ARR;
}
func fast    = () #callConv(@pthr.CallingConvention.FAST)    -> Void {}
func cold    = () #callConv(@pthr.CallingConvention.COLD)    -> Void {}
func c       = () #callConv(@pthr.CallingConvention.C)       -> Void {}
func win_api = () #callConv(@pthr.CallingConvention.WIN_API) -> Void {}

func entry = () #entry -> UI8 {
	fast();
	cold();
	c();
	win_api();
	
	return 0;
}
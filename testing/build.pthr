def std = @import("std");
def std_exp = @import("std_exp/std_exp.pthr");
def build_exp = @import("std_exp/building.pthr");


func entry = () #entry -> UI8 {
	var build = new build_exp.PantherBuild{
		output       = std.build.Output.PIR,
		target       = new build_exp.Target{os = build_exp.Target.OS.WINDOWS, arch = build_exp.Target.Arch.X86_64},
		optimization = new build_exp.PantherBuild.Optimiziation(),
		addDebugInfo = true,
		numThreads   = 12,
	};


	const warns = new @build.PackageWarningSettings{
		methodCallOnNonMethod        = true,
		memberTypeByValueAccessor    = true,
		deleteMovedFromExpr          = true,
		deleteTriviallyDeletableType = true,
		comptimeIfCond               = true,
		alreadyUnsafe                = true,
		experimentalF80              = true,
	};


	// build.addStdLib("../extern/Panther-std/std/"); // shipped path
	// build.addStdLib("../../Panther-std/std");
	// add_std_exp(build, copy warns);


	var test_package_uninit: build_exp.Package*uninit = build.packages.append();
	test_package_uninit.* = new build_exp.Package{
		path     = "./",
		name     = "test",
		warnings = copy warns,
	};

	var test_package: build_exp.Package*mut = @makeInitPtr(test_package_uninit);
	test_package.sourceFiles.append().* = "test.pthr";


	// build.cFamilyHeaders.append().* = new build_exp.CFamilyHeader{
	// 	path = "test.h", isCPP = false, addIncludesToPubApi = false
	// };


	try build.build() else { return 1; };
	
	return 0;
}



func add_std_exp = (build: build_exp.PantherBuild mut, warns: @build.PackageWarningSettings in) #rt -> Void {
	build.packages.append().* = new build_exp.Package{
		path        = "./std_exp",
		name        = "std_exp",
		warnings    = forward warns,
		sourceFiles = new std_exp.StaticArrayList<{[Char:*], 4}>(
			new [[Char:*]:4]["atomic.pthr", "StaticArrayList.pthr", "StaticString.pthr", "std_exp.pthr"],
		),
	};
}